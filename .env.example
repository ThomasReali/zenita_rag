# OpenRouter — OpenAI-compatible API. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Any OpenRouter model slug. Examples: openai/gpt-4o, anthropic/claude-3.5-sonnet,
# google/gemini-2.0-flash-001, meta-llama/llama-3.3-70b-instruct
CHAT_MODEL=openai/gpt-4o

# Vector store — Qdrant (embedded local; set QDRANT_URL to use a running server instead)
COLLECTION_NAME=documents
QDRANT_PATH=./qdrant_data
# QDRANT_URL=http://localhost:6333

# Ingestion / retrieval — chunking strutturale dimensionato alla finestra di embedding (token)
CHUNK_MAX_TOKENS=480
CHUNK_MIN_TOKENS=200
RETRIEVAL_K=5
DATA_DIR=./data

# Governance — gate
SCORE_THRESHOLD=0.82
AMBIGUITY_JUDGE=1

# Governance — obsolescenza & data-poisoning (audit DETERMINISTICO, no-LLM)
STATUS_FILTER_ENABLED=1
EXCLUDED_STATUSES=obsolete,poisoned,draft
OBSOLETE_NOTICE_ENABLED=1
GOVERNANCE_MASTER_FILE=./data/_governance/obsolescence.csv
NORMATTIVA_AUDIT_ENABLED=0
GOVERNANCE_LOG_PATH=./governance_log.db

# Governance — audit log query + Data Anonymization GDPR
QUERY_LOG_ENABLED=1
QUERY_LOG_PATH=./query_log.db
LOG_RETENTION_MONTHS=6

# Governance — pseudonimizzazione reversibile della PII (GDPR Art. 32)
PII_MASKING_ENABLED=1
# Backend: auto (Presidio se installato, altrimenti regex) | regex | presidio
PII_BACKEND=auto
PII_SPACY_MODEL=it_core_news_lg
